# Supabase Configuration
# Copy this file to .env and fill in your values

# Supabase Project ID
VITE_SUPABASE_PROJECT_ID=your-project-id-here

# Supabase Anonymous/Public Key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Edge Function Slug (optional, defaults to "make-server-918f1e54")
VITE_SUPABASE_EDGE_FUNCTION_SLUG=make-server-918f1e54

# Full Supabase URL (optional, will be constructed from project ID if not provided)
# VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Environment (development, production, etc.)
VITE_ENV=development
